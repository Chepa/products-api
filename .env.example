DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=products_api
DB_USER=app
DB_PASS=app

APP_BASE_URI=/
APP_API_BASE=/api/v1
APP_TIMEZONE=UTC
# true = Volt recompile each request; API 500 responses include exception message; use only locally
APP_DEBUG=false

# POST /api/v1/tokens/generate — max attempts per IP per window (0 = disable limit)
TOKEN_GENERATE_LIMIT=30
TOKEN_GENERATE_WINDOW=3600

# docker-compose: mysql hostname is `mysql`, DB_USER/DB_PASS as in compose.yaml
