{
  "name": "products-api/phalcon-app",
  "description": "Product catalog API on Phalcon",
  "type": "project",
  "require": {
    "php": ">=8.2",
    "ext-pdo": "*",
    "ext-json": "*",
    "ext-phalcon": "*",
    "vlucas/phpdotenv": "^5.6",
    "ext-curl": "*"
  },
  "require-dev": {
    "phalcon/ide-stubs": "^5.12",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
